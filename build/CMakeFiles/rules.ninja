#############################################
# Rule for running custom commands.

rule CUSTOM_COMMAND
  command = $COMMAND
  description = $DESC


#############################################
# Rule for re-running cmake.

rule RERUN_CMAKE
  command = "D:\PUsing\CMake 4.1.1\bin\cmake.exe" --regenerate-during-build -SE:\Project\MelosyneTest\Math\fast_math -BE:\Project\MelosyneTest\Math\fast_math\build
  description = Re-running CMake...
  generator = 1


#############################################
# Rule for cleaning all built files.

rule CLEAN
  command = D:\PUsing\ninja\ninja.exe $FILE_ARG -t clean $TARGETS
  description = Cleaning all built files...


#############################################
# Rule for printing all primary targets available.

rule HELP
  command = D:\PUsing\ninja\ninja.exe -t targets
  description = All primary targets available:

